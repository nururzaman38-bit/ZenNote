<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header Controls -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/img_drag_handle"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_drag_handle"
                android:contentDescription="Drag to reorder"
                android:padding="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/img_drag_handle"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"
                android:text="TASK MATRIX / GRID"
                android:textColor="@color/secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <ImageButton
                android:id="@+id/btn_delete_block"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_delete"
                app:tint="@color/accent_error"
                android:contentDescription="Delete Block" />

        </RelativeLayout>

        <!-- Column Headers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#2E3A52"
            android:paddingVertical="8dp"
            android:paddingHorizontal="4dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="#"
                android:gravity="center"
                android:textColor="@color/muted"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="Done"
                android:gravity="center"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="3"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Task Description"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1.5"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Category"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Dynamic Rows Container -->
        <LinearLayout
            android:id="@+id/ll_grid_rows"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Add Row Button -->
        <Button
            android:id="@+id/btn_add_grid_row"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="+ Add Task Row"
            android:textColor="@color/secondary"
            android:textSize="13sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
