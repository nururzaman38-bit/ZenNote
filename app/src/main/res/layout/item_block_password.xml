<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header Controls -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/img_drag_handle"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_drag_handle"
                android:contentDescription="Drag to reorder"
                android:padding="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/img_drag_handle"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"
                android:text="SECURE PASSWORD VAULT"
                android:textColor="#F59E0B"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Lock Status Toggle -->
            <ImageButton
                android:id="@+id/btn_lock_status"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_toStartOf="@id/btn_delete_block"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_lock"
                app:tint="#F59E0B"
                android:contentDescription="Lock/Unlock Vault Item" />

            <ImageButton
                android:id="@+id/btn_delete_block"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_delete"
                app:tint="@color/accent_error"
                android:contentDescription="Delete Block" />

        </RelativeLayout>

        <!-- Input fields (Account Name, Username, Password) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/et_vault_account"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:hint="Account / Service (e.g., Netflix)"
                android:textColorHint="@color/muted"
                android:textColor="@color/on_surface"
                android:textSize="15sp"
                android:textStyle="bold"
                android:importantForAutofill="no"
                android:inputType="textCapWords"
                android:maxLines="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Username:"
                    android:textColor="@color/muted"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/et_vault_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="user@example.com"
                    android:textColorHint="@color/muted"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:importantForAutofill="no"
                    android:inputType="textEmailAddress"
                    android:maxLines="1" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Password:"
                    android:textColor="@color/muted"
                    android:textSize="13sp" />

                <!-- Password input field (can be masked or visible) -->
                <EditText
                    android:id="@+id/et_vault_password"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="••••••••"
                    android:textColorHint="@color/muted"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:importantForAutofill="no"
                    android:inputType="textPassword"
                    android:maxLines="1" />

                <!-- Authenticate and reveal button -->
                <Button
                    android:id="@+id/btn_reveal_password"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REVEAL"
                    android:textColor="#F59E0B"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
